{
  "name": "agenttrust-backend",
  "version": "1.0.0",
  "description": "Backend API for AgentTrust - Identity & Audit Layer for Agentic Browsers",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test-connection": "node test-connection.js",
    "create-db": "node scripts/create-database.js",
    "create-users": "node scripts/create-users-table.js",
    "add-status-column": "node scripts/add-status-column.js",
    "add-session-screenshot": "node scripts/add-session-screenshot-columns.js",
    "migrate": "node migrations/migrate.js",
    "setup-db": "npm run create-db && npm run create-users && npm run add-status-column && npm run add-session-screenshot"
  },
  "keywords": [
    "agent",
    "browser",
    "audit",
    "auth0",
    "security"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1005.0",
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/s3-request-presigner": "^3.1005.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.0.1",
    "morgan": "^1.10.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  }
}
