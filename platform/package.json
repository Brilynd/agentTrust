{
  "name": "@agenttrust/platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev --workspace @agenttrust/platform-api",
    "dev:worker": "npm run dev --workspace @agenttrust/platform-worker",
    "dev:dashboard": "npm run dev --workspace @agenttrust/platform-dashboard",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema ./prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  }
}
